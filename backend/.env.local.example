# Backend runtime environment for the treasury API.

# Supabase project URL used by repositories and auth access.
SUPABASE_URL=https://your-project.supabase.co

# Public Supabase anon key used by anon client flows.
SUPABASE_ANON_KEY=your-anon-key

# Service role key used for privileged server-side data access.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Node environment for runtime behavior and logging.
NODE_ENV=development

# Port for the backend Next.js runtime.
BACKEND_PORT=3001

# Comma-separated browser origins allowed to call backend API routes.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Optional JWT secret for locally validated tokens or future auth hardening.
JWT_SECRET=replace-with-a-32-character-minimum-secret
